---
import type { Lang } from "@/content/site";
import { CONTENT, SECTIONS } from "@/content/site";
import Layout from "@/layouts/Layout.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import StatusDot from "@/components/StatusDot.astro";
import SectionLabel from "@/components/SectionLabel.astro";
import Card from "@/components/Card.astro";
import Badge from "@/components/Badge.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = CONTENT[lang];
---

<Layout title={`${t.hero.name} — ${t.hero.role}`} lang={lang}>
  <LanguageSwitcher current={lang} />

  <main class="main">
    <!-- HERO -->
    <section class="section">
      <div class="hero-status">
        <StatusDot color="cyan" />
        <span class="hero-status__text">{t.hero.status}</span>
      </div>
      <h1 class="hero-title">
        <span class="hero-title__prefix">~/</span>matoanselmo<span class="cursor" />
      </h1>
      <div class="hero-meta">
        {t.hero.name} · <span class="text-muted">{t.hero.role}</span>
      </div>
      <p class="hero-tagline">{t.hero.tagline}</p>
    </section>

    <!-- ABOUT -->
    {SECTIONS.about && (
      <section class="section">
        <SectionLabel>{t.about.label}</SectionLabel>
        {t.about.body.map((para) => (
          <p class="body-text">{para}</p>
        ))}
      </section>
    )}

    <!-- PROJECTS -->
    {SECTIONS.projects && (
      <section class="section">
        <SectionLabel>{t.projects.label}</SectionLabel>
        <div class="project-list">
          {t.projects.items.map((p) => (
            <Card>
              <div class="project">
                <div class="project__header">
                  <a href={p.repo} target="_blank" class="project__name">{p.name}</a>
                  <span class="project__meta">{p.meta}</span>
                </div>
                <p class="project__desc">{p.desc}</p>
                <div class="project__tags">
                  {p.tags.map((tag) => (
                    <Badge color="cyan">{tag}</Badge>
                  ))}
                </div>
              </div>
            </Card>
          ))}
        </div>
      </section>
    )}

    <!-- EXPERIENCE -->
    {SECTIONS.experience && (
      <section class="section">
        <SectionLabel>{t.experience.label}</SectionLabel>
        <div class="experience-list">
          {t.experience.items.map((x) => (
            <div class="experience-item">
              <div class="experience-item__period">{x.period}</div>
              <div>
                <div class="experience-item__role">{x.role}</div>
                <div class="experience-item__org">{x.org}</div>
                <p class="experience-item__desc">{x.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- NOW -->
    {SECTIONS.now && (
      <section class="section">
        <SectionLabel color="amber">{t.now.label}</SectionLabel>
        <Card raised>
          <div>
            <p class="now__intro">{t.now.intro}</p>
            <ul class="now__list">
              {t.now.items.map((item) => (
                <li class="now__item">
                  <span class="now__arrow">&rarr;</span><span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="now__updated">
              {t.now.updatedLabel} {t.now.updated}
            </div>
          </div>
        </Card>
      </section>
    )}

    <!-- FOOTER -->
    <footer class="footer">
      <a href="https://github.com/matoanselmo" target="_blank" class="footer__link">
        <span class="text-muted">~/</span>github.com/matoanselmo
      </a>
      <span class="footer__note">{t.footer.note}</span>
    </footer>
  </main>
</Layout>

<style>
  .main {
    min-height: 100vh;
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-12);
  }

  .section {
    margin-bottom: var(--space-16);
  }

  /* Hero */
  .hero-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .hero-status__text {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent-cyan);
  }

  .hero-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-display);
    margin: 0 0 var(--space-4);
  }

  .hero-title__prefix {
    color: var(--text-2);
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 0.92em;
    transform: translateY(0.08em);
    margin-left: 2px;
    background: var(--accent-violet);
    animation: mato-blink 1.1s steps(1) infinite;
  }

  .hero-meta {
    font-size: var(--text-md);
    color: var(--text);
    margin-bottom: var(--space-3);
  }

  .text-muted {
    color: var(--text-2);
  }

  .hero-tagline {
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--text-2);
    max-width: 56ch;
    margin: 0;
  }

  /* About */
  .body-text {
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--text);
    max-width: 62ch;
    margin: 0 0 var(--space-4);
  }

  /* Projects */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .project__name {
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--accent-violet);
  }

  .project__meta {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-3);
    white-space: nowrap;
  }

  .project__desc {
    font-size: var(--text-sm);
    line-height: var(--leading-body);
    color: var(--text-2);
    margin: 0;
  }

  .project__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Experience */
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .experience-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-6);
  }

  .experience-item__period {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-3);
    padding-top: 3px;
  }

  .experience-item__role {
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--text);
    margin-bottom: 2px;
  }

  .experience-item__org {
    font-size: var(--text-sm);
    color: var(--accent-cyan);
    margin-bottom: var(--space-3);
  }

  .experience-item__desc {
    font-size: var(--text-sm);
    line-height: var(--leading-body);
    color: var(--text-2);
    margin: 0;
  }

  /* Now */
  .now__intro {
    font-size: var(--text-sm);
    line-height: var(--leading-body);
    color: var(--text-2);
    margin: 0 0 var(--space-4);
  }

  .now__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .now__item {
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--text);
    display: flex;
    gap: var(--space-3);
  }

  .now__arrow {
    color: var(--accent-amber);
  }

  .now__updated {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-3);
    margin-top: var(--space-6);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--surface-raised);
    padding-top: var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__link {
    font-size: var(--text-sm);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer__note {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-3);
  }
</style>

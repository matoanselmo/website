---
interface Props {
  value?: number;
  color?: "violet" | "cyan" | "amber";
  label?: string;
  showValue?: boolean;
}

const { value = 0, color = "violet", label, showValue = true } = Astro.props;

const palette: Record<string, string> = {
  violet: "var(--accent-violet)",
  cyan: "var(--accent-cyan)",
  amber: "var(--accent-amber)",
};

const c = palette[color] ?? palette.violet;
const pct = Math.max(0, Math.min(100, value));
---

<div class="progress">
  {(label || showValue) && (
    <div class="progress__header">
      {label && <span class="progress__label">{label}</span>}
      {showValue && <span class="progress__value" style={`color: ${c};`}>{pct}%</span>}
    </div>
  )}
  <div class="progress__track">
    <div class="progress__fill" style={`width: ${pct}%; background: ${c};`} />
  </div>
</div>

<style>
  .progress__header {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .progress__label {
    font-size: var(--text-xs);
    color: var(--text-2);
  }

  .progress__value {
    font-size: var(--text-xs);
  }

  .progress__track {
    height: 4px;
    background: var(--surface-raised);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress__fill {
    height: 100%;
    border-radius: 2px;
    transition: width var(--transition);
  }
</style>

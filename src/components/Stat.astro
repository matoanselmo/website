---
interface Props {
  value: string;
  unit?: string;
  label: string;
  delta?: string;
  deltaColor?: "ok" | "error" | "muted" | "cyan";
}

const { value, unit, label, delta, deltaColor = "ok" } = Astro.props;

const deltaPalette: Record<string, string> = {
  ok: "var(--color-ok)",
  error: "var(--color-error)",
  muted: "var(--text-3)",
  cyan: "var(--accent-cyan)",
};
---

<div>
  <div class="stat__value">
    {value}{unit && <span class="stat__unit">{unit}</span>}
  </div>
  <div class="stat__label">{label}</div>
  {delta && (
    <div class="stat__delta" style={`color: ${deltaPalette[deltaColor] ?? deltaPalette.ok};`}>
      {delta}
    </div>
  )}
</div>

<style>
  .stat__value {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--accent-cyan);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-display);
  }

  .stat__unit {
    font-size: var(--text-md);
  }

  .stat__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-2);
    margin-top: var(--space-1);
  }

  .stat__delta {
    font-size: var(--text-xs);
    margin-top: var(--space-1);
  }
</style>

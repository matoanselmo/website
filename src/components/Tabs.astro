---
interface Tab {
  id: string;
  label: string;
}

interface Props {
  tabs: Tab[];
  active?: string;
}

const { tabs, active } = Astro.props;
---

<div class="tabs">
  {tabs.map((tab) => (
    <button
      class:list={["tabs__item", { "tabs__item--active": tab.id === active }]}
      type="button"
      data-tab-id={tab.id}
    >
      {tab.label}
    </button>
  ))}
</div>

<style>
  .tabs {
    display: flex;
    gap: var(--space-6);
    border-bottom: 1px solid var(--surface-raised);
  }

  .tabs__item {
    font-family: var(--font);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2) 0;
    color: var(--text-2);
    box-shadow: none;
    transition: color var(--transition);
  }

  .tabs__item--active {
    color: var(--text);
    box-shadow: inset 0 -2px 0 var(--accent-violet);
  }
</style>

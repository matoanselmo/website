---
interface Props {
  type?: "accent" | "value" | "string" | "comment" | "ok";
}

const { type = "value" } = Astro.props;

const colors: Record<string, string> = {
  accent: "var(--accent-violet)",
  value: "var(--accent-cyan)",
  string: "var(--accent-amber)",
  comment: "var(--text-3)",
  ok: "var(--color-ok)",
};

const color = colors[type] ?? colors.value;
---

<span style={`color: ${color};`}><slot /></span>

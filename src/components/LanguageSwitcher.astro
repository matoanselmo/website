---
interface Props {
  current: "en" | "pt";
}

const { current } = Astro.props;
---

<div class="lang-switcher">
  <a
    href="/"
    class:list={["lang-btn", { "lang-btn--active": current === "en" }]}
    title="English"
    aria-label="English"
  >
    &#x1F1FA;&#x1F1F8;
  </a>
  <a
    href="/pt/"
    class:list={["lang-btn", { "lang-btn--active": current === "pt" }]}
    title="Português"
    aria-label="Português"
  >
    &#x1F1E7;&#x1F1F7;
  </a>
</div>

<style>
  .lang-switcher {
    position: fixed;
    top: var(--space-6);
    right: var(--space-6);
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 2px;
    background: var(--surface-raised);
    border-radius: 4px;
    padding: 3px;
  }

  .lang-btn {
    font: inherit;
    font-size: 15px;
    line-height: 1;
    padding: 5px 8px;
    border-radius: 3px;
    border: none;
    cursor: pointer;
    transition: opacity 120ms ease, box-shadow 120ms ease;
    text-decoration: none;
    display: inline-block;
    opacity: 0.45;
    filter: grayscale(0.6);
    background: transparent;
    box-shadow: none;
  }

  .lang-btn--active {
    background: var(--surface-overlay);
    box-shadow: var(--stripe-active);
    opacity: 1;
    filter: none;
  }
</style>

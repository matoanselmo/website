---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Lang } from "@/content/site";

interface Props {
  current: Lang;
}

const { current } = Astro.props;

const languages: { code: Lang; label: string; flag: string }[] = [
  { code: "en", label: "English", flag: "\u{1F1FA}\u{1F1F8}" },
  { code: "pt", label: "Português", flag: "\u{1F1E7}\u{1F1F7}" },
];
---

<div class="lang-switcher">
  {languages.map((l) => (
    <a
      href={getRelativeLocaleUrl(l.code)}
      class:list={["lang-btn", { "lang-btn--active": current === l.code }]}
      title={l.label}
      aria-label={l.label}
      aria-current={current === l.code ? "true" : undefined}
    >
      {l.flag}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    position: fixed;
    top: var(--space-6);
    right: var(--space-6);
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 2px;
    background: var(--surface-raised);
    border-radius: 4px;
    padding: 3px;
  }

  .lang-btn {
    font: inherit;
    font-size: 15px;
    line-height: 1;
    padding: 5px 8px;
    border-radius: 3px;
    border: none;
    cursor: pointer;
    transition: opacity 120ms ease, box-shadow 120ms ease;
    text-decoration: none;
    display: inline-block;
    opacity: 0.45;
    filter: grayscale(0.6);
    background: transparent;
    box-shadow: none;
  }

  .lang-btn--active {
    background: var(--surface-overlay);
    box-shadow: var(--stripe-active);
    opacity: 1;
    filter: none;
  }
</style>

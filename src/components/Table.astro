---
interface Column {
  key: string;
  label: string;
  align?: "left" | "center" | "right";
}

interface Props {
  columns: Column[];
  rows: Record<string, string>[];
}

const { columns, rows } = Astro.props;
---

<table class="table">
  <thead>
    <tr>
      {columns.map((col) => (
        <th style={col.align ? `text-align: ${col.align};` : undefined}>
          {col.label}
        </th>
      ))}
    </tr>
  </thead>
  <tbody>
    {rows.map((row, i) => (
      <tr>
        {columns.map((col) => (
          <td
            class:list={{ "td--first": i === 0 }}
            style={col.align ? `text-align: ${col.align};` : undefined}
          >
            {row[col.key]}
          </td>
        ))}
      </tr>
    ))}
  </tbody>
</table>

<style>
  .table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    font-family: var(--font);
  }

  th {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-3);
    text-align: left;
    padding: var(--space-2) var(--space-3);
    padding-top: 0;
  }

  td {
    color: var(--text);
    padding: var(--space-3);
    vertical-align: middle;
    border-top: 1px solid var(--surface-raised);
  }

  .td--first {
    border-top: none;
  }
</style>
